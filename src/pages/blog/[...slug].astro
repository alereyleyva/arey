---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={post.data.title} description={post.data.description}>
  <nav class="mb-12">
    <a href="/" class="text-sm text-neutral-400 no-underline hover:underline">
      &larr; Back
    </a>
  </nav>

  <article>
    <header class="mb-10">
      <h1 class="text-2xl font-bold leading-snug mb-2">{post.data.title}</h1>
      <time class="text-sm text-neutral-400">{formatDate(post.data.date)}</time>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
