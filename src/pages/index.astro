---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<Base title="Alejandro Rey">
  <header class="mb-12">
    <p class="font-bold text-sm mb-8 tracking-wide">AREY</p>
    <p class="text-neutral-700 dark:text-neutral-300 mb-3">
      Writing about software engineering, AI, and technical things that catch my attention.
    </p>
    <p class="text-sm text-neutral-400 space-x-3">
      <a href="https://github.com/alereyleyva" class="no-underline hover:underline">GitHub</a>
      <span>·</span>
      <a href="/rss.xml" class="no-underline hover:underline">RSS</a>
    </p>
  </header>

  <section>
    {posts.map((post) => (
      <a
        href={`/blog/${post.id}`}
        class="group flex items-baseline gap-3 py-3 border-b border-neutral-200 dark:border-neutral-800 no-underline text-inherit"
      >
        <span class="shrink-0 group-hover:underline underline-offset-2">{post.data.title}</span>
        <span class="flex-1 border-b border-dashed border-neutral-200 dark:border-neutral-800 relative -top-[0.4em]"></span>
        <span class="shrink-0 text-sm text-neutral-400 tabular-nums">{formatDate(post.data.date)}</span>
      </a>
    ))}
  </section>
</Base>
