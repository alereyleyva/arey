---
import PostPage from '@/components/PostPage.astro';
import { getAlternatePost, getPostsByLocale, getPostSlug } from '@/i18n/utils';

export async function getStaticPaths() {
  const posts = await getPostsByLocale('en');
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const alternatePost = await getAlternatePost(post, 'es');
---

<PostPage locale="en" post={post} alternatePost={alternatePost} />
