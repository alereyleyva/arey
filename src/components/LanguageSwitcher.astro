---
import { defaultLocale, locales, type Locale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/utils';

interface Props {
  locale: Locale;
  path?: string;
}

const { locale, path = '' } = Astro.props;
---

<nav class="flex items-center gap-2 text-xs text-neutral-400" aria-label="Language switcher">
  {locales.map((entryLocale) => {
    const href = getLocalizedPath(entryLocale, path);
    const isActive = entryLocale === locale;

    return (
      <a
        href={href}
        hrefLang={entryLocale}
        aria-current={isActive ? 'page' : undefined}
        class:list={[
          'no-underline hover:underline',
          isActive && 'text-neutral-700 dark:text-neutral-200',
        ]}
      >
        {entryLocale.toUpperCase()}
      </a>
    );
  })}
</nav>
